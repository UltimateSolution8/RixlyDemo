REACT_APP_BACKEND_URL=https://rixly-landing.preview.emergentagent.com
WDS_SOCKET_PORT=443
ENABLE_HEALTH_CHECK=false
CI=false

# =============================================================================
# SANITY CMS CONFIGURATION
# =============================================================================
# To enable the blog CMS, follow these steps:
#
# 1. Create a Sanity project at https://www.sanity.io/manage
#    - Sign up for a free account
#    - Click "Create new project"
#    - Copy the "Project ID" (e.g., "abc123xyz")
#
# 2. Deploy the Sanity Studio
#    - Go to the /LandingNew/sanity folder
#    - Run: npm install (or yarn install)
#    - Run: sanity deploy
#    - This will give you a URL like https://your-project.sanity.studio
#
# 3. Configure this file with your Project ID
#    - Uncomment and fill in the values below:
#
# REACT_APP_SANITY_PROJECT_ID=your-project-id-here
# REACT_APP_SANITY_DATASET=production
#
# 4. Rebuild/deploy your frontend to see changes
#
# =============================================================================

# Example (uncomment and replace with your actual project ID):
# REACT_APP_SANITY_PROJECT_ID=abc123xyz
# REACT_APP_SANITY_DATASET=production
